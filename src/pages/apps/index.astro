---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const apps = (await getCollection('apps')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Applications" description="Interactive digital humanities applications by Aslisho Qurboniev" wide>
  <h1>Applications</h1>
  <p class="muted" style="max-width: 44rem;">
    Interactive tools and visualisations from my research — text reuse
    explorers, network graphs, and digital corpora for the study of premodern
    Arabic and Persian texts.
  </p>
  <div class="card-grid">
    {apps.map((app) => (
      <a class="card" href={`/apps/${app.id}/`}>
        {app.data.image && (
          <img src={app.data.image} alt="" class="thumb" loading="lazy" />
        )}
        <h3>{app.data.title}</h3>
        <p>{app.data.description}</p>
        {app.data.tags.length > 0 && (
          <p class="tags">
            {app.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .thumb {
    width: 100%;
    height: 10rem;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 0.9rem;
    border: 1px solid var(--color-border);
  }

  .tags {
    margin-top: 0.75rem !important;
  }
</style>
